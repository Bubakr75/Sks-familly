rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 SÉCURITÉ : seuls les utilisateurs AUTHENTIFIÉS peuvent accéder aux données.
    // L'auth anonyme est activée dans la console Firebase.
    // Avant : allow if true → n'importe qui sur internet.
    // Maintenant : allow if request.auth != null → protégé des attaques externes.
    function isSignedIn() {
      return request.auth != null;
    }

    // Familles
    match /families/{familyId} {

      // Document famille lui-même
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;

      // Enfants
      match /children/{childId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Historique
      match /history/{entryId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Objectifs
      match /goals/{goalId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Punitions
      match /punishments/{punishmentId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Notes
      match /notes/{noteId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Immunites
      match /immunities/{immunityId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Echanges (trades)
      match /trades/{tradeId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Tribunal
      match /tribunal/{caseId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Badges personnalisés
      match /custom_badges/{badgeId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Temps d'écran
      match /screen_time/{key} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Tokens FCM
      match /fcm_tokens/{deviceId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Profils parents
      match /parent_profiles/{profileId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Demandes enfants (validation parentale)
      // ⚠️ IMPORTANT : la collection s'appelle 'requests' (pas 'pending_requests')
      match /requests/{requestId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Tâches (chores)
      match /chores/{choreId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }
  }
}
