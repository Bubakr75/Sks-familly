rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Familles - accessibles en lecture/ecriture pour les membres connectes
    match /families/{familyId} {

      // Document famille lui-meme
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;

      // Enfants
      match /children/{childId} {
        allow read: if true;
        allow write: if true;
      }

      // Historique
      match /history/{entryId} {
        allow read: if true;
        allow write: if true;
      }

      // Objectifs
      match /goals/{goalId} {
        allow read: if true;
        allow write: if true;
      }

      // Punitions
      match /punishments/{punishmentId} {
        allow read: if true;
        allow write: if true;
      }

      // Notes
      match /notes/{noteId} {
        allow read: if true;
        allow write: if true;
      }

      // Immunites
      match /immunities/{immunityId} {
        allow read: if true;
        allow write: if true;
      }

      // Echanges (trades)
      match /trades/{tradeId} {
        allow read: if true;
        allow write: if true;
      }

      // Tribunal
      match /tribunal/{caseId} {
        allow read: if true;
        allow write: if true;
      }

      // Badges personnalisés
      match /custom_badges/{badgeId} {
        allow read: if true;
        allow write: if true;
      }

      // Temps d'écran
      match /screen_time/{key} {
        allow read: if true;
        allow write: if true;
      }

      // Tokens FCM
      match /fcm_tokens/{deviceId} {
        allow read: if true;
        allow write: if true;
      }

      // Profils parents
      match /parent_profiles/{profileId} {
        allow read: if true;
        allow write: if true;
      }

      // Requêtes pending
      match /pending_requests/{requestId} {
        allow read: if true;
        allow write: if true;
      }

      // Tâches (chores)
      match /chores/{choreId} {
        allow read: if true;
        allow write: if true;
      }
    }
  }
}
